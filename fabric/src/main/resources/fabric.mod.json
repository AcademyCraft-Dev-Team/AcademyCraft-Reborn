{
  "schemaVersion": 1,
  "id": "academy",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "AcademyCraft-Dev-Team"
  ],
  "contact": {
    "sources": "https://github.com/AcademyCraft-Dev-Team/AcademyCraft-Reborn"
  },
  "license": "${license}",
  "icon": "assets/academy/textures/item/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "org.academy.fabric.AcademyCraftFabric"
    ],
    "client": [
      "org.academy.fabric.AcademyCraftFabricClient"
    ],
    "jei_mod_plugin": [
      "org.academy.internal.common.compatibility.JEIPlugin"
    ]
  },
  "mixins": [
    "academy-fabric.mixins.json",
    "academy.mixins.json"
  ],
  "depends": {
    "fabricloader": "*",
    "fabric": "*",
    "minecraft": "${minecraft_version}",
    "special-model-loader": "*"
  },
  "accessWidener": "academy.accesswidener"
}